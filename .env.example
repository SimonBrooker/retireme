# Copy this to .env and change the secret key before deploying anywhere public.
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_PATH=/data/retirement.db

# Set to "true" once this is served over real HTTPS (e.g. behind nginx with a
# valid cert, optionally behind Cloudflare too). Leave "false" for plain HTTP
# (e.g. a home LAN with no reverse proxy) — otherwise the session cookie won't
# be sent by the browser at all, and you won't be able to log in.
SECURE_COOKIES=false
